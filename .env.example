TAG=prod
PUBLIC_PORT=80
DATA_PATH=
RESTART_POLICY=no

# MongoDB Connection Options
# Option 1: Use connection string (recommended for external MongoDB services)
# HYPHE_MONGODB_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/hyphe

# Option 2: Use individual host/port settings (for local MongoDB)
# HYPHE_MONGODB_HOST=localhost
# HYPHE_MONGODB_PORT=27017
# HYPHE_MONGODB_DBNAME=hyphe
